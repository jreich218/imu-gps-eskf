@misc{nuscenes-canbus-linear-accel-specific-force-local-2026-03-26,
  title = {Data from nuScenes CAN bus expansion used for local analysis of IMU linear\_accel as specific force},
  author = {{nuScenes}},
  year = {2020},
  note = {Published February 2020 by nuScenes. Jason Reich ran local analysis tests on this data. IMU linear_accel was rotated into the gravity-aligned frame defined by q, and near-stationary moments were identified from the pose stream. Over 147006 matched near-stationary samples, the gravity-aligned stationary mean was [0.00016, 0.00224, 9.79705] and the median was [-0.00007, 0.00126, 9.79619], supporting the interpretation of linear_accel as specific force with gravity handled separately.}
}
